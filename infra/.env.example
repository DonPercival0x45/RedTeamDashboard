# Copy to infra/.env for local docker-compose.
# Production secrets live in Azure Key Vault, not this file.

POSTGRES_USER=rtd
POSTGRES_PASSWORD=rtd
POSTGRES_DB=rtd

# Which LLM backend the agent uses. Switches at app.orchestrator.llm.default_llm().
#   anthropic - paid Claude API (default)
#   ollama    - local LLM via the bundled ollama compose service (free)
#   azure     - Azure OpenAI (production target)
# LLM_PROVIDER=ollama

# Anthropic (only used when LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-7   # claude-sonnet-4-6 / claude-haiku-4-5-20251001 are cheaper for dev

# Platform-owned Suggestion Box evaluator. Keeps feedback evaluation off
# analyst BYO balances and pins a consistent inexpensive model.
# PLANNER_PROVIDER=openai
# PLANNER_MODEL=gpt-4o-mini
# PLANNER_API_KEY=
# PLANNER_ENDPOINT=
# PLANNER_DAILY_LIMIT_PER_USER=20

# Ollama (only used when LLM_PROVIDER=ollama)
# OLLAMA_HOST=http://ollama:11434
# OLLAMA_MODEL=llama3.1:8b

# Azure OpenAI (only used when LLM_PROVIDER=azure; production via Key Vault on AKS)
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_DEPLOYMENT=
# AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Entra ID OIDC (filled in when auth lands).
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
